<h2 style="margin-right:1em">Change your password</h2>
<div class="1flex space-x-12"
<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div class="field">
    <%= f.label :password, "New password" %><br />
    <% if @minimum_password_length %>
      <em>(<%= @minimum_password_length %> characters minimum)</em><br />
    <% end %>
    <%= f.password_field :password,
class: "py-2 px-4 rounded border ring-0
    focus:ring-4 focus:ring-orange-100 focus:shadow-none
    1dark:text-slate-800 focus:border-orange-500 focus:outline-none",
autofocus: true, autocomplete: "new-password" %>
  </div>
  <br>
  <div class="field">
    <%= f.label :password_confirmation, "Confirm new password" %><br />
    <%= f.password_field :password_confirmation,
class: "py-2 px-4 rounded border ring-0
    focus:ring-4 focus:ring-orange-100 focus:shadow-none
    1dark:text-slate-800 focus:border-orange-500 focus:outline-none",
autocomplete: "new-password" %>
  </div>
  <br>
  <div class="actions actionsdark:text-slate-500
  font-bold text-2xl">
    <%= f.submit "Change my password" %>
  </div>
<% end %>

<div  style="margin-left:1em; margin-right:1em"
class="dark:text-slate-400">
  <%= render "devise/shared/links" %>
</div>
