<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "Blog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Blog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <header class="1bg-white
  text-slate-300
  dark:bg-slate-700 dark:text-slate-500
  dark:text-slate-400 p-4 flex items-center justify-around">
    <h1 tyle="margin-left:5em; margin-right:5em;"
    class="text-slate-900 dark:text-white
    font-bold text-4xl">Manager</h1>

    <nav style="margin-left:1.25em; margin-right:1.5em;"
    class="text-teal-400 space-x-1">
      <a class="1nav-link active"
      aria-current="page" href="/pages/home">Home</a>
      <%= link_to 'Posts', posts_path,
      class: "1nav-link" %>
      <%= link_to 'Projects', projects_path,
      class: "1nav-link" %>
      <% if user_signed_in? %>
      <% end %>
    </nav>
    <div style="1margin-left:0.12px; margin-right:1em;"
    class="text-gray-400 flex space-x-1">
      <div style="margin-top:8px;" data-controller="dark-mode">
        <%= image_tag("icons/_VS12.svg",
        class: 'w-16 h-16 hover:cursor-pointer',
        data: { action: 'click->dark-mode#toggle'}) %>
      </div>
      <div style="margin-top:8px; margin-bottom:8px; margin-left:10px; margin-right:5x;" data-controller="dark-mode">
        <ul class="1nav-link 1dropdown-menu">
          <% if user_signed_in? %>
          <li class="1nav-link 1dropdown-item">
            <%= link_to "Hi, #{current_user.email}",
             edit_user_registration_path, class:'nav-link' %>
           </li>
           <li class="1nav-link 1dropdown-item">
            <%= button_to(
              "Log Out",
              destroy_user_session_path,
              method: :delete
            ) %>
          <% else %>
          <li>
            <%= link_to "Sign In",
             new_user_session_path, class:'nav-link' %>
          </li>
          <li>
            <%= link_to "Sign Up",
             new_user_registration_path, class:'nav-link' %>
          </li>
          <% end %>
        </ul>
      </div>
    </div>
  </header>

  <body class="dark:bg-gray-100 h-full font-sans
  antialiased font-normal leading-normal bg-gray-50
  1dark:bg-slate-900 1dark:text-slate-50">
    <main class="container mx-auto mt-8 px-5 flex">
      <%= yield %>
    </main>
    <br><hr>
    <%= render 'shared/footer' %>
  </body>
</html>
