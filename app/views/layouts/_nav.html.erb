    </a>
    <div class="navigation__list__wrapper">
      <button aria-controls="navigation__mobile-menu-trigger" aria-haspopup="true"
      class="navigation__mobile-menu-trigger closed" id="navigation__mobile-menu-trigger">
      </button>
      <ul class="navigation__list">
        <li class="navigation__item">
          <a href="/pages/home">Home</a>
        </li>
        <li class="navigation__item">
          <%= link_to 'Posts', posts_path,
          class: "text-orange-500 1nav-link" %>
        </li>
        <li class="navigation__item">
          <a href="/public/conferences">Conferences</a>
        </li>
        <li class="navigation__item">
          <a href="/public/open_source/">Open Source</a>
        </li>
        <li class="navigation__item">
          <a href="/public/scholarships/">Scholarships</a>
        </li>
        <li class="navigation__item">
          <a href="/public/volunteer/">Volunteer</a>
        </li>
        <li class="navigation__item">
          <a href="/public/corporate-sponsorship/">Sponsorship</a>
        </li>
        <li class="navigation__item">
          <a href="/public/support/">Support Us</a>
        </li>
        <li class="navigation__item">
          <a href="/public/">Shop</a>
        </li>
        <li class="navigation__item">
          <a href="/public/news/">News</a>
        </li>
      </ul>
