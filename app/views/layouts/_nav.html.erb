            <%= button_to(
              "Log Out",
              destroy_user_session_path,
              method: :delete
            ) %>
          <% else %>
          <li>
            <%= link_to "Sign In",
             new_user_session_path, class:'nav-link' %>
          </li>
          <li>
            <%= link_to "Sign Up",
