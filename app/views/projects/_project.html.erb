<div id="<%= dom_id project %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= project.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Thumbnail url:</strong>
    <%= project.thumbnail_url %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Video url:</strong>
    <%= project.video_url %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Body:</strong>
    <%= project.body %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Pro:</strong>
    <%= project.pro? ? "Yes" : "No" %>
  </div>
</div>
